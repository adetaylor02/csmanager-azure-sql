# =============================================================
# Critical Spares Manager — Environment Configuration (EXAMPLE)
# =============================================================
# Copy this file to `.env` (local) or configure these values in
# Azure App Service / Static Web Apps application settings.
# DO NOT commit real secrets to source control.
# -------------------------------------------------------------

# ---- App identity ----
VITE_APP_NAME="Critical Spares Manager"
VITE_API_BASE_URL="/api"

# ---- Production kill-switch for the localStorage mock backend ----
# MUST be "true" in Azure Static Web Apps so the UI never silently falls
# back to localStorage when /api/* is unreachable. Leave unset locally to
# keep the mock fallback active for Lovable preview / offline dev.
VITE_DISABLE_MOCK="true"


# ---- Microsoft Entra ID (Azure AD) ----
# Register an SPA application in Entra ID and copy the values here.
VITE_TENANT_ID="00000000-0000-0000-0000-000000000000"
VITE_CLIENT_ID="00000000-0000-0000-0000-000000000000"
VITE_REDIRECT_URI="https://spares.contoso.example.com/auth/callback"

# ---- Database (server-side only) ----
# Use ONE of the following depending on the chosen backend.
DATABASE_URL="postgresql://user:password@host:5432/spares"
AZURE_SQL_CONNECTION_STRING="Server=tcp:<server>.database.windows.net,1433;Database=<db>;Authentication=Active Directory Default;"
DATAVERSE_ENVIRONMENT_URL="https://<org>.crm.dynamics.com"

# ---- Power BI embedded reporting ----
POWERBI_WORKSPACE_ID="00000000-0000-0000-0000-000000000000"
POWERBI_REPORT_ID="00000000-0000-0000-0000-000000000000"

# ---- Microsoft Teams notifications (Incoming Webhook) ----
TEAMS_WEBHOOK_URL="https://outlook.office.com/webhook/REPLACE_ME"

# ---- Internal CMMS (Maximo / SAP PM / custom) ----
CMMS_API_BASE_URL="https://cmms.contoso.example.com/api"
CMMS_CLIENT_ID="REPLACE_ME"
CMMS_CLIENT_SECRET="REPLACE_ME"
